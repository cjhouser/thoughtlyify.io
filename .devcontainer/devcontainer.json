// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/alpine
{
	"name": "devenv",
	// Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
	"image": "devenv:0.13.2",
	"mounts": [
		"type=volume,source=devvol,destination=/mnt/devvol,ro=false"
	],
	"runArgs": [
		"--network=devnet",
		"--hostname=devenv"
	],
	"postCreateCommand": {
		"volume-owner": "chown -R $(id -u):$(id -g) /mnt/devvol",
		".aws-link": "ln -s /mnt/devvol/aws ~/.aws",
		".kube-link": "ln -s /mnt/devvol/kube ~/.kube",
		".ssh-link": "rm -rf ~/.ssh && ln -s /mnt/devvol/ssh ~/.ssh",
		".az-link": "ln -s /mnt/devvol/az ~/.azure"
	},
	"customizations": {
		"vscode": {
			"settings": {
				"[opentofu][opentofu-vars]": {
					"editor.defaultFormatter": "opentofu.vscode-opentofu",
					"editor.formatOnSave": true,
					"editor.formatOnSaveMode": "file"
				},
				"files.associations": {
					"*.go.tmpl": "go",
					"*.tf.tmpl": "opentofu"
				}
			},
			"extensions": [
				"golang.go",
				"ms-azuretools.vscode-docker",
				"vmware.vscode-concourse",
				"opentofu.vscode-opentofu"
			]
		}
	}
}
